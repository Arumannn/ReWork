# =============================================================================
# Recon Plan — Environment Configuration (.env)
# =============================================================================
# Copy this file to .env and fill in your target's details.
# The recon-plan sources this file at every phase.
# =============================================================================

# === Program Info ===
PROGRAM_NAME="Example Program"
PROGRAM_PLATFORM="HackerOne"
RESEARCHER="Destroyerofthisworld"

# === Target Definition ===
# Seed domains for subdomain enumeration (space-separated)
SEED_DOMAINS="example.com api.example.com"

# Regex for filtering in-scope subdomains (grep -E pattern)
SCOPE_WILDCARD='\.(example\.com|example\.io)$'

# Explicit in-scope domains (one per line)
SCOPE_EXPLICIT="www.example.com
app.example.com
admin.example.com
api.example.com"

# Domains/subdomains explicitly out of scope (one per line)
OUT_OF_SCOPE="staging.example.com
dev.example.com
old.example.com"

# === Mobile Targets (optional — leave blank if not in scope) ===
ANDROID_PACKAGES="com.example.app"
IOS_BUNDLE_IDS="com.example.ios"

# === Rate Limits ===
RL_LIGHT=10
RL_MEDIUM=50
RL_AGGRESSIVE=100
THREADS=5

# === Working Directory (auto-created) ===
# Leave as-is to use the plan's parent directory
WORKDIR="."

# === API Keys (optional) ===
OTX_API_KEY=""
SHODAN_API_KEY=""
CENSYS_API_ID=""
CENSYS_API_SECRET=""
GITHUB_TOKEN=""

# === Auth / Traffic Headers (optional) ===
# Also accepted via CLI: --cookie "session=abc123" --header "Authorization: Bearer xyz"
AUTH_COOKIE=""
AUTH_HEADER="X-Bug-Bounty: Destroyerofthisworld"

# === Google Dorking (optional) ===
# Dork queries will be auto-generated from seed domains
GOOGLE_DORKS_ENABLED=true

# === GitHub Dorking (optional) ===
# Requires GITHUB_TOKEN to auto-search; without token, only dork queries are saved
GITHUB_DORKS_ENABLED=true

# === Strict Rate Limit Hosts (if applicable) ===
# Hosts that require slower scanning (one per line)
STRICT_HOSTS="login.example.com
api.login.example.com"
